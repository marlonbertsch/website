---
const { title = "Marlons site"} = Astro.props;
const { background = "background2.jpg"} = Astro.props;
import Link from '../components/Link.astro';
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<!--<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />-->
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="background"></div>
		<nav>
			<Link href="/">Home</Link>
			<Link href="about">About</Link>
			<Link href="blog">Blog</Link>
			<Link href="projects">Projects</Link>
		</nav>
		<div id="ham-menu">
		<img src="burger-menu-svgrepo-com.svg" alt="" srcset="">
		</div>
		<div id="line-container">
			<div id="line"></div>
			<div id="line2"></div>
		</div>
		<div class="main-container">
			<slot />
		</div>
		<div id="bg-image" style={`--bg-url: url('/${background}')`} />
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'CaviarDreams';
		src: url('/CaviarDreams.ttf') format('truetype');  /* lowercase 'd' */
	}
	@font-face {
		font-family: 'calivorne';
		src: url('/Voguella.ttf') format('truetype');  /* already correct */
	}
	h1 {
		font-family: 'calivorne', sans-serif !important;
		font-weight: lighter;
		font-size: 3.5em;
		color: rgb(0, 0, 51);
	}

	.main-container {
		margin: 2em;
	}
	#line-container {
		display: flex;
		justify-content: space-between;
	}

	#line, #line2{
		width: 30vw;
		background-color: black;
		height: 0.10em;
	}

	#line2 {
		width: 3vw;
	}

	#bg-image {
		background-image: var(--bg-url);
		background-repeat: no-repeat;
		background-position: 50% 50%;
		background-size: cover;
		height: 300px;
		width: auto;
	}

	nav {
		display: flex;
		justify-content: center;
		gap: 10px;
		margin: 2em;
	}

	nav a, nav span, nav a:visited, nav a:link {
		font-family: 'CaviarDreams', sans-serif !important;
		font-size: 1.2em;
		color: black;
	}

	nav *:hover {
		text-decoration: underline;
		/* text-decoration-color: #d66b6b;  */
 		text-underline-offset: 5px;   
	}
	#ham-menu {
		margin-top: 30px;
		display: flex;
		justify-content: end;
	}
	#ham-menu * {
		pointer-events: none;
		user-select: none;
		width: 60px;
		height: auto;
		margin-right: 15px;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	html {
		background: radial-gradient(circle,rgba(240, 237, 233, 1) 0%, rgba(247, 244, 235, 1) 56%, rgba(255, 252, 227, 1) 100%);
		/* background-image: url('background1.jpg'); */
		background-position: 0px 0px;
		background-repeat:initial;
		background-attachment:scroll;
		background-size: 1000px;
		background-size: 300vw;
	}
	.background {
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 50vh;
		background-image: url(dotted.png);
		background-size: 500px auto;
		background-repeat: repeat;
		background-position: bottom;
		mask-image: linear-gradient(to top, black 70%, transparent 100%);
		-webkit-mask-image: linear-gradient(to top, black 70%, transparent 100%);
		z-index: -1;
	}
	@media (min-width: 700px) {
		#bg-image {
			background-size: cover;
			width: 600px;
		}
	}
	@media (min-width: 500px) {
		#ham-menu {
			display: none;
		}
		#bg-image {
			background-size: cover;
			width: 600px;
		}
	}
	@media (max-width: 700px) {
		#line, #line2{
			background-color: rgba(240, 248, 255, 0);
		}
	}
	@media (max-width: 500px) {
		nav {
			display: none;
		}
		body {
			margin: 0px 0px ;
		}
		#line {
			background-color: rgba(240, 248, 255, 0);
		}
		#bg-image {
			height: 200px;
		}
	}
</style>